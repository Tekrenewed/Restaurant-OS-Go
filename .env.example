# ---------------------------------------------------------
# RESTAURANT OS - ENVIRONMENT VARIABLES
# ---------------------------------------------------------

# Server Configuration
PORT=8080

# Database Connection (PostgreSQL)
# Local Docker Example: postgres://postgres:password@localhost:5432/restaurant_os?sslmode=disable
# GCP Cloud SQL Example: postgres://USER:PASSWORD@/DB_NAME?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
# Free Supabase/Neon Example: postgresql://postgres:password@db.supabase.co:5432/postgres
DATABASE_URL=

# ---------------------------------------------------------
# EXTERNAL INTEGRATIONS (Optional for local development)
# ---------------------------------------------------------

# Dojo Payment API Integrations (Phase 3 & 4)
DOJO_API_KEY=your_dojo_test_api_key
DOJO_API_URL=https://api.dojo.tech/v1

# ESC/POS Receipt Printer IP (Wait for Phase 4)
PRINTER_IP=192.168.0.100

# Uber Direct Dispatch APIs (Future Phase)
UBER_CLIENT_ID=your_uber_client_id
UBER_ACCESS_TOKEN=your_uber_access_token
UBER_DIRECT_API_URL=https://api.uber.com/v1

# Firebase credentials
# Note: Google Cloud Run automatically inherits ADC (Application Default Credentials).
# Localy, make sure to run: gcloud auth application-default login
